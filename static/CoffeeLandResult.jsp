<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Coffee Land Details Result</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="bg-light">

    <div class="container col-md-6 mt-5">

      <h3 class="text-center mb-4 text-success">Coffee Land Details Submitted</h3>

      <div class="border p-4 rounded shadow-sm bg-white">

        <p><strong>Size by Acre:</strong> ${acre}</p>
        <p><strong>Total Plants:</strong> ${plants}</p>
        <p><strong>Total Yield:</strong> ${yield}</p>
        <p><strong>Expenditure:</strong> ${expenditure}</p>
        <p><strong>Profit Made:</strong> ${profit}</p>
        <p><strong>Fertilizer Quantity Used:</strong> ${fertilizer}</p>

        <div class="mt-4 text-center">
          <a href="CoffeeLand.jsp" class="btn btn-primary">Go Back</a>
        </div>

      </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
